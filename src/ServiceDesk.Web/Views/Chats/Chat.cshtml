@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    var chatId = (int)ViewBag.ChatId;
    var userId = (int)ViewBag.UserId;
    var pollingInterval = Configuration.GetValue<int>("Chat:PollingIntervalMs", 2000);
}

<div class="d-flex align-items-center mb-3 gap-2">
    <a href="/Chats/Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left"></i>
    </a>
    <h5 class="mb-0" id="chatTitle"><i class="bi bi-chat-left-text"></i> Чат</h5>
</div>

<div class="card">
    <div class="chat-container company-chat-fullpage">
        <div id="chatMessages" class="chat-messages">
            <div class="chat-empty">
                <i class="bi bi-chat-text"></i>
                <span>Загрузка сообщений...</span>
            </div>
        </div>
        <div id="emojiPicker" class="emoji-picker"></div>
        <!-- Превью ответа на сообщение -->
        <div id="chatReplyPreview" class="chat-reply-preview" style="display:none">
            <div class="chat-reply-preview-content">
                <div class="chat-reply-preview-sender" id="replyPreviewSender"></div>
                <div class="chat-reply-preview-text" id="replyPreviewText"></div>
            </div>
            <button type="button" class="chat-reply-preview-close" id="cancelReply" title="Отменить ответ">&times;</button>
        </div>
        <!-- Превью выбранных файлов -->
        <div id="chatFilePreview" class="chat-file-preview"></div>
        <form id="chatForm" class="chat-input-area">
            <button type="button" class="btn-emoji" id="emojiToggle" title="Эмодзи">
                <i class="bi bi-emoji-smile"></i>
            </button>
            <button type="button" class="btn-emoji" id="chatAttachBtn" title="Прикрепить файл">
                <i class="bi bi-paperclip"></i>
            </button>
            <input type="file" id="chatFileInput" multiple accept="image/*,video/*,.pdf,.doc,.docx,.xls,.xlsx" style="display:none" />
            <textarea id="chatInput" rows="1" placeholder="Сообщение..." autocomplete="off"></textarea>
            <button type="submit" class="btn-send" title="Отправить">
                <i class="bi bi-send-fill"></i>
            </button>
        </form>
    </div>
</div>

<!-- Модальное окно просмотра вложений -->
<div class="modal fade" id="attachmentModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h6 class="modal-title" id="attachmentModalTitle"></h6>
                <div class="ms-auto d-flex align-items-center gap-2">
                    <small class="text-muted" id="attachmentCounter"></small>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Закрыть"></button>
                </div>
            </div>
            <div class="modal-body text-center p-2 position-relative" id="attachmentModalBody">
                <button type="button" id="galleryPrev"
                        class="btn btn-light rounded-circle position-absolute top-50 start-0 translate-middle-y ms-2 shadow-sm"
                        style="width:40px;height:40px;z-index:10;" onclick="galleryNav(-1)">
                    <i class="bi bi-chevron-left"></i>
                </button>
                <div id="galleryContent"></div>
                <button type="button" id="galleryNext"
                        class="btn btn-light rounded-circle position-absolute top-50 end-0 translate-middle-y me-2 shadow-sm"
                        style="width:40px;height:40px;z-index:10;" onclick="galleryNav(1)">
                    <i class="bi bi-chevron-right"></i>
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/company-chat.js" asp-append-version="true"></script>
    <script>
        initCompanyChat(@chatId, @userId, @pollingInterval);
    </script>
}
