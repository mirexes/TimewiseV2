@using ServiceDesk.Core.DTOs.Users
@using ServiceDesk.Core.DTOs.Common
@model CreateUserDto
@{
    var userId = (int)ViewBag.UserId;
    var userName = ViewBag.UserName as string ?? "Пользователь";
    ViewData["Title"] = $"Редактирование: {userName}";
    var clients = ViewBag.Clients as IEnumerable<SelectOptionDto> ?? Enumerable.Empty<SelectOptionDto>();
    var avatarUrl = ViewBag.AvatarUrl as string;
}

@functions {
    string GetRoleName(UserRole role) => role switch
    {
        UserRole.Technician => "Техник",
        UserRole.Engineer => "Инженер",
        UserRole.ChiefEngineer => "Главный инженер",
        UserRole.Logist => "Логист",
        UserRole.ManagerTimewise => "Менеджер Timewise",
        UserRole.ManagerClient => "Менеджер клиента",
        UserRole.Client => "Клиент",
        UserRole.Moderator => "Модератор",
        _ => role.ToString()
    };
}

<div class="mb-3">
    <a href="/Users/Details/@userId" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left"></i> К пользователю
    </a>
</div>

<div class="card" style="max-width: 600px;">
    <div class="card-header"><h5 class="mb-0">Редактирование пользователя</h5></div>
    <div class="card-body">
        <form asp-action="Edit" asp-route-id="@userId" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <!-- Аватар -->
            <div class="mb-3">
                <label class="form-label">Аватар</label>
                <div class="d-flex align-items-center gap-3 mb-2">
                    <div id="avatarPreview" style="width:80px;height:80px;border-radius:50%;overflow:hidden;background:var(--bs-secondary-bg);display:flex;align-items:center;justify-content:center;">
                        @if (!string.IsNullOrEmpty(avatarUrl))
                        {
                            <img src="@avatarUrl" alt="Аватар" style="width:100%;height:100%;object-fit:cover;" id="avatarImg" />
                        }
                        else
                        {
                            <i class="bi bi-person-fill" style="font-size:2.5rem;color:var(--bs-secondary-color);" id="avatarPlaceholder"></i>
                        }
                    </div>
                    <div>
                        <input type="file" name="avatar" id="avatarInput" class="form-control form-control-sm" accept="image/*" />
                        @if (!string.IsNullOrEmpty(avatarUrl))
                        {
                            <div class="form-check mt-1">
                                <input type="checkbox" name="removeAvatar" value="true" class="form-check-input" id="removeAvatarCheck" />
                                <label for="removeAvatarCheck" class="form-check-label small text-danger">Удалить аватар</label>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="LastName" class="form-label">Фамилия *</label>
                <input asp-for="LastName" class="form-control" />
                <span asp-validation-for="LastName" class="text-danger small"></span>
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="FirstName" class="form-label">Имя *</label>
                    <input asp-for="FirstName" class="form-control" />
                    <span asp-validation-for="FirstName" class="text-danger small"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="MiddleName" class="form-label">Отчество</label>
                    <input asp-for="MiddleName" class="form-control" />
                    <span asp-validation-for="MiddleName" class="text-danger small"></span>
                </div>
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Phone" class="form-label">Телефон *</label>
                    <input asp-for="Phone" type="tel" class="form-control" />
                    <span asp-validation-for="Phone" class="text-danger small"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Email" class="form-label">Email</label>
                    <input asp-for="Email" type="email" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>
            </div>
            <div class="mb-3">
                <label asp-for="Role" class="form-label">Роль *</label>
                <select asp-for="Role" class="form-select" id="roleSelect">
                    @foreach (var role in Enum.GetValues<UserRole>())
                    {
                        <!option value="@role" @(Model.Role == role ? "selected" : "")>@GetRoleName(role)</!option>
                    }
                </select>
                <span asp-validation-for="Role" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Company" class="form-label">Компания</label>
                <input asp-for="Company" class="form-control" />
                <span asp-validation-for="Company" class="text-danger small"></span>
            </div>
            <div class="mb-3" id="clientSelectGroup" style="display: none;">
                <label asp-for="ClientId" class="form-label">Клиент (организация)</label>
                <select asp-for="ClientId" class="form-select">
                    <option value="">— Не выбран —</option>
                    @foreach (var client in clients)
                    {
                        <!option value="@client.Id" @(Model.ClientId == client.Id ? "selected" : "")>@client.Text</!option>
                    }
                </select>
                <span asp-validation-for="ClientId" class="text-danger small"></span>
            </div>
            <div class="mb-3 form-check">
                <input asp-for="IsActive" type="checkbox" class="form-check-input" />
                <label asp-for="IsActive" class="form-check-label">Активен</label>
            </div>

            <button type="submit" class="btn btn-primary">
                <i class="bi bi-check-lg"></i> Сохранить
            </button>
            <a href="/Users/Details/@userId" class="btn btn-outline-secondary ms-2">Отмена</a>
        </form>
    </div>
</div>

@section Scripts {
    <script src="~/js/users.js" asp-append-version="true"></script>
    <script>
        // Предпросмотр выбранного аватара
        (function () {
            const input = document.getElementById('avatarInput');
            const preview = document.getElementById('avatarPreview');
            const removeCheck = document.getElementById('removeAvatarCheck');

            if (!input || !preview) return;

            input.addEventListener('change', function () {
                const file = this.files[0];
                if (!file) return;

                const reader = new FileReader();
                reader.onload = function (e) {
                    preview.innerHTML = '<img src="' + e.target.result + '" alt="Аватар" style="width:100%;height:100%;object-fit:cover;" />';
                    if (removeCheck) removeCheck.checked = false;
                };
                reader.readAsDataURL(file);
            });

            if (removeCheck) {
                removeCheck.addEventListener('change', function () {
                    if (this.checked) input.value = '';
                });
            }
        })();
    </script>
}
