@model PagedResultDto<TicketListDto>
@{
    ViewData["Title"] = "Заявки";
    var filter = ViewBag.Filter as TicketFilterDto ?? new TicketFilterDto();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <span class="text-muted">Всего: @Model.TotalCount</span>
    </div>
    @if (User.GetRole() is not UserRole.Client and not UserRole.Technician)
    {
        <a href="/Tickets/Create" class="btn btn-primary">
            <i class="bi bi-plus-lg"></i> Новая заявка
        </a>
    }
</div>

<!-- Фильтры -->
<div class="card mb-4">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-2">
                <label class="form-label small">Статус</label>
                <select name="Status" class="form-select form-select-sm">
                    <option value="">Все</option>
                    @foreach (var status in Enum.GetValues<TicketStatus>())
                    {
                        <option value="@status" selected="@(filter.Status == status)">@status</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small">Тип</label>
                <select name="Type" class="form-select form-select-sm">
                    <option value="">Все</option>
                    @foreach (var type in Enum.GetValues<TicketType>())
                    {
                        <option value="@type" selected="@(filter.Type == type)">@type</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label small">Поиск</label>
                <input name="SearchQuery" value="@filter.SearchQuery" class="form-control form-control-sm"
                       placeholder="Номер, описание, адрес..." />
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-outline-primary btn-sm w-100">
                    <i class="bi bi-funnel"></i> Фильтр
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Список заявок -->
@if (!Model.Items.Any())
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-inbox fs-1"></i>
        <p class="mt-2">Заявок не найдено</p>
    </div>
}
else
{
    <div id="ticketsList">
        @foreach (var ticket in Model.Items)
        {
            <div class="card mb-3 ticket-card" onclick="location.href='/Tickets/Details/@ticket.Id'"
                 style="cursor: pointer;">
                <div class="card-body p-3">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <div>
                            <span class="fw-bold">@ticket.TicketNumber</span>
                            @await Html.PartialAsync("_StatusBadge", ticket.Status)
                        </div>
                        <small class="text-muted">@ticket.CreatedAt.ToString("dd.MM.yy HH:mm")</small>
                    </div>

                    <p class="mb-1 text-truncate">@ticket.Description</p>

                    <div class="d-flex justify-content-between align-items-center">
                        <small class="text-muted">
                            <i class="bi bi-geo-alt"></i> @ticket.Address
                        </small>
                        @if (ticket.EngineerName is not null)
                        {
                            <small class="text-muted">
                                <i class="bi bi-person"></i> @ticket.EngineerName
                            </small>
                        }
                    </div>

                    @if (ticket.Deadline.HasValue)
                    {
                        var isOverdue = ticket.Deadline < DateTime.Now;
                        <div class="mt-1">
                            <small class="@(isOverdue ? "text-danger fw-bold" : "text-muted")">
                                <i class="bi bi-clock"></i>
                                Дедлайн: @ticket.Deadline.Value.ToString("dd.MM.yy HH:mm")
                                @if (isOverdue) { <span>— ПРОСРОЧЕНА</span> }
                            </small>
                        </div>
                    }
                </div>
            </div>
        }
    </div>

    @await Html.PartialAsync("_Pagination", Model)
}
