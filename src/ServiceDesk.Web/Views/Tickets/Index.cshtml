@model PagedResultDto<TicketListDto>
@{
    ViewData["Title"] = "Заявки";
    var filter = ViewBag.Filter as TicketFilterDto ?? new TicketFilterDto();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <span class="text-muted">Всего: @Model.TotalCount</span>
    </div>
        <a href="/Tickets/Create" class="btn btn-primary">
            <i class="bi bi-plus-lg"></i> Новая заявка
        </a>
</div>

<!-- Фильтры -->
<div class="card mb-4">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-2">
                <label class="form-label small">Статус</label>
                <select name="Status" class="form-select form-select-sm">
                    <option value="">Все</option>
                    @foreach (var status in Enum.GetValues<TicketStatus>())
                    {
                        var statusName = status switch
                        {
                            TicketStatus.New => "Новая",
                            TicketStatus.Processed => "Взяли в работу",
                            TicketStatus.CompletedRemotely => "Дистанционно",
                            TicketStatus.PartsApproval => "Согласование",
                            TicketStatus.RepairApproved => "Согласована",
                            TicketStatus.DepartureConfirmation => "Подтверждение",
                            TicketStatus.EngineerEnRoute => "В пути",
                            TicketStatus.InProgress => "Выполнение",
                            TicketStatus.Completed => "Выполнена",
                            TicketStatus.ContinuationRequired => "Продолжение",
                            TicketStatus.Cancelled => "Отменена",
                            _ => status.ToString()
                        };
                        <option value="@status" selected="@(filter.Status == status)">@statusName</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small">Тип</label>
                <select name="Type" class="form-select form-select-sm">
                    <option value="">Все</option>
                    @foreach (var type in Enum.GetValues<TicketType>())
                    {
                        var typeName = type switch
                        {
                            TicketType.Repair => "Ремонт",
                            TicketType.Maintenance => "ТО",
                            TicketType.Installation => "Установка",
                            TicketType.Dismantling => "Демонтаж",
                            TicketType.Delivery => "Поставка",
                            TicketType.Consultation => "Консультация",
                            _ => type.ToString()
                        };
                        <option value="@type" selected="@(filter.Type == type)">@typeName</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label small">Поиск</label>
                <input name="SearchQuery" value="@filter.SearchQuery" class="form-control form-control-sm"
                       placeholder="Номер, описание, адрес..." />
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-outline-primary btn-sm w-100">
                    <i class="bi bi-funnel"></i> Фильтр
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Список заявок -->
@if (!Model.Items.Any())
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-inbox fs-1"></i>
        <p class="mt-2">Заявок не найдено</p>
    </div>
}
else
{
    <div id="ticketsList">
        @foreach (var ticket in Model.Items)
        {
            <div class="card mb-3 ticket-card" onclick="location.href='/Tickets/Details/@ticket.Id'"
                 style="cursor: pointer;">
                <div class="card-body p-3">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <div>
                            <span class="fw-bold">@ticket.TicketNumber</span>
                            @await Html.PartialAsync("_StatusBadge", ticket.Status)
                            @await Html.PartialAsync("_TypeBadge", ticket.Type)
                            <br /><span class="text-muted">Создана - @ticket.CreatedAt.ToString("dd.MM.yy HH:mm")</span>
                        </div>
                        @if (ticket.HasWorkAct)
                        {
                            var photosJson = System.Text.Json.JsonSerializer.Serialize(
                                ticket.CompletionPhotos.Select(p => new { filePath = p.FilePath, fileName = p.FileName }));
                            <div class="text-end flex-shrink-0 ms-3">
                                <button class="btn btn-outline-success btn-sm"
                                        onclick="event.stopPropagation(); openWorkActSlider(@ticket.Id, '@(ticket.AvrPhotoPath ?? "")', @photosJson)">
                                    <i class="bi bi-file-earmark-check"></i> АВР
                                </button>
                                @if (ticket.WorkCompletedAt.HasValue)
                                {
                                    <div class="mt-1">
                                        <small class="text-muted">
                                            <i class="bi bi-check-circle"></i> @ticket.WorkCompletedAt.Value.ToString("dd.MM.yy HH:mm")
                                        </small>
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    <p class="mb-1 text-truncate">@ticket.Description</p>
                    @if (!string.IsNullOrEmpty(ticket.Address))
                    {
                        <a href="https://yandex.ru/maps/?text=@(Uri.EscapeDataString(ticket.Address))"
                           target="_blank" rel="noopener noreferrer" class="text-decoration-none"
                           onclick="event.stopPropagation();">
                            <small class="link-primary"><i class="bi bi-geo-alt"></i> @ticket.Address</small>
                        </a>
                    }
                    else
                    {
                        <small class="text-muted"><i class="bi bi-geo-alt"></i> Адрес не указан</small>
                    }
                    @if (ticket.EngineerName is not null)
                    {
                        <br />
                        <small class="text-muted">
                            <i class="bi bi-person"></i>Исполнитель - @ticket.EngineerName
                        </small>
                    }

                    @if (ticket.Deadline.HasValue)
                    {
                        var isOverdue = ticket.Deadline < DateTime.Now;
                        <div class="mt-1">
                            <small class="@(isOverdue ? "text-danger fw-bold" : "text-muted")">
                                <i class="bi bi-clock"></i>
                                Дедлайн: @ticket.Deadline.Value.ToString("dd.MM.yy HH:mm")
                                @if (isOverdue) { <span>— ПРОСРОЧЕНА</span> }
                            </small>
                        </div>
                    }
                </div>
            </div>
        }
    </div>

    @await Html.PartialAsync("_Pagination", Model)
}

<!-- Слайдер просмотра АВР -->
<div class="modal fade" id="workActSliderModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content bg-dark border-0">
            <div class="modal-header border-0 py-2">
                <span class="text-white small" id="workActSliderCounter"></span>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-0 text-center position-relative" style="min-height:300px;">
                <button id="workActSliderPrev" class="btn btn-dark rounded-circle position-absolute start-0 top-50 translate-middle-y ms-2"
                        style="width:40px;height:40px;z-index:10;opacity:0.7;"
                        onclick="workActSliderNav(-1)">
                    <i class="bi bi-chevron-left"></i>
                </button>
                <div id="workActSliderContent" class="d-flex align-items-center justify-content-center" style="min-height:300px;">
                </div>
                <button id="workActSliderNext" class="btn btn-dark rounded-circle position-absolute end-0 top-50 translate-middle-y me-2"
                        style="width:40px;height:40px;z-index:10;opacity:0.7;"
                        onclick="workActSliderNav(1)">
                    <i class="bi bi-chevron-right"></i>
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    // Слайдер АВР на странице списка заявок
    var workActSliderPhotos = [];
    var workActSliderIndex = 0;

    function openWorkActSlider(ticketId, avrPath, completionPhotos) {
        workActSliderPhotos = [];

        // Добавляем основное фото АВР
        if (avrPath) {
            workActSliderPhotos.push({ filePath: avrPath, fileName: 'АВР' });
        }

        // Добавляем фото акта выполненных работ
        if (completionPhotos && completionPhotos.length > 0) {
            completionPhotos.forEach(function(p) {
                workActSliderPhotos.push(p);
            });
        }

        if (workActSliderPhotos.length === 0) return;

        workActSliderIndex = 0;
        renderWorkActSlider();
        new bootstrap.Modal(document.getElementById('workActSliderModal')).show();
    }

    function renderWorkActSlider() {
        var photo = workActSliderPhotos[workActSliderIndex];
        var content = document.getElementById('workActSliderContent');
        content.innerHTML = '<img src="' + photo.filePath + '" alt="' + photo.fileName + '" class="img-fluid" style="max-height:70vh;" />';

        var counter = document.getElementById('workActSliderCounter');
        counter.textContent = (workActSliderIndex + 1) + ' / ' + workActSliderPhotos.length;

        document.getElementById('workActSliderPrev').style.display = workActSliderIndex > 0 ? '' : 'none';
        document.getElementById('workActSliderNext').style.display = workActSliderIndex < workActSliderPhotos.length - 1 ? '' : 'none';
    }

    function workActSliderNav(direction) {
        workActSliderIndex += direction;
        if (workActSliderIndex < 0) workActSliderIndex = 0;
        if (workActSliderIndex >= workActSliderPhotos.length) workActSliderIndex = workActSliderPhotos.length - 1;
        renderWorkActSlider();
    }
</script>
