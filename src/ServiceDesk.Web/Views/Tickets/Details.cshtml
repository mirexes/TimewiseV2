@model TicketDetailDto
@{
    ViewData["Title"] = $"Заявка {Model.TicketNumber}";
}

<div class="mb-3">
    <a href="/Tickets" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left"></i> К списку
    </a>
</div>

<div class="row g-4">
    <!-- Основная информация -->
    <div class="col-md-8">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">@Model.TicketNumber</h5>
                @await Html.PartialAsync("_StatusBadge", Model.Status)
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label small text-muted">Тип</label>
                        <p class="mb-2">@Model.Type</p>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small text-muted">Приоритет</label>
                        <p class="mb-2">@Model.Priority</p>
                    </div>
                    <div class="col-12">
                        <label class="form-label small text-muted">Описание</label>
                        <p class="mb-2">@Model.Description</p>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.Comment))
                    {
                        <div class="col-12">
                            <label class="form-label small text-muted">Комментарий</label>
                            <p class="mb-2">@Model.Comment</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Допустимые переходы -->
        @if (Model.AllowedTransitions.Length > 0)
        {
            <div class="card mt-3">
                <div class="card-header">
                    <h6 class="mb-0">Действия</h6>
                </div>
                <div class="card-body d-flex gap-2 flex-wrap">
                    @foreach (var transition in Model.AllowedTransitions)
                    {
                        <button class="btn btn-outline-primary btn-sm"
                                onclick="updateStatus(@Model.Id, '@transition')">
                            @transition
                        </button>
                    }
                </div>
            </div>
        }

        <!-- Чат -->
        <div class="card mt-3">
            <div class="card-header">
                <h6 class="mb-0"><i class="bi bi-chat-dots"></i> Чат</h6>
            </div>
            <div class="card-body">
                <div id="chatMessages" class="chat-messages mb-3" style="max-height: 400px; overflow-y: auto;">
                    <p class="text-muted text-center small">Загрузка сообщений...</p>
                </div>
                <form id="chatForm" class="d-flex gap-2">
                    <input type="text" id="chatInput" class="form-control form-control-sm"
                           placeholder="Написать сообщение..." />
                    <button type="submit" class="btn btn-primary btn-sm">
                        <i class="bi bi-send"></i>
                    </button>
                </form>
            </div>
        </div>
    </div>

    <!-- Боковая панель -->
    <div class="col-md-4">
        <div class="card mb-3">
            <div class="card-header"><h6 class="mb-0">Детали</h6></div>
            <div class="card-body">
                <div class="mb-3">
                    <small class="text-muted">Точка обслуживания</small>
                    <p class="mb-1 fw-bold">@Model.ServicePointName</p>
                    <small class="text-muted"><i class="bi bi-geo-alt"></i> @Model.Address</small>
                </div>
                @if (Model.EquipmentModel is not null)
                {
                    <div class="mb-3">
                        <small class="text-muted">Оборудование</small>
                        <p class="mb-0">@Model.EquipmentModel (@Model.EquipmentSerialNumber)</p>
                    </div>
                }
                @if (Model.EngineerName is not null)
                {
                    <div class="mb-3">
                        <small class="text-muted">Специалист</small>
                        <p class="mb-0"><i class="bi bi-person"></i> @Model.EngineerName</p>
                    </div>
                }
                <div class="mb-3">
                    <small class="text-muted">Создал</small>
                    <p class="mb-0">@Model.CreatedByName</p>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-header"><h6 class="mb-0">Даты</h6></div>
            <div class="card-body">
                <div class="mb-2">
                    <small class="text-muted">Создана</small>
                    <p class="mb-0">@Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")</p>
                </div>
                @if (Model.Deadline.HasValue)
                {
                    <div class="mb-2">
                        <small class="text-muted">Дедлайн</small>
                        <p class="mb-0 @(Model.Deadline < DateTime.Now ? "text-danger" : "")">
                            @Model.Deadline.Value.ToString("dd.MM.yyyy HH:mm")
                        </p>
                    </div>
                }
                @if (Model.WorkStartedAt.HasValue)
                {
                    <div class="mb-2">
                        <small class="text-muted">Начало работ</small>
                        <p class="mb-0">@Model.WorkStartedAt.Value.ToString("dd.MM.yyyy HH:mm")</p>
                    </div>
                }
                @if (Model.WorkCompletedAt.HasValue)
                {
                    <div class="mb-2">
                        <small class="text-muted">Завершена</small>
                        <p class="mb-0 text-success">@Model.WorkCompletedAt.Value.ToString("dd.MM.yyyy HH:mm")</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/chat.js"></script>
    <script src="~/js/tickets.js"></script>
    <script>
        // Инициализация чата для текущей заявки
        initChat(@Model.Id);
    </script>
}
