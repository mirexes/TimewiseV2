@model TicketDetailDto
@{
    ViewData["Title"] = $"Заявка {Model.TicketNumber}";
}

<div class="mb-3">
    <a href="/Tickets/Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left"></i> К списку
    </a>
</div>

<div class="row g-4">
    <!-- Основная информация -->
    <div class="col-md-8">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">@Model.TicketNumber</h5>
                @await Html.PartialAsync("_StatusBadge", Model.Status)
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label small text-muted">Тип</label>
                        <p class="mb-2">@Model.TypeDisplayName</p>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small text-muted">Приоритет</label>
                        <p class="mb-2">@Model.PriorityDisplayName</p>
                    </div>
                    <div class="col-12">
                        <label class="form-label small text-muted">Описание</label>
                        <p class="mb-2">@Model.Description</p>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.Comment))
                    {
                        <div class="col-12">
                            <label class="form-label small text-muted">Комментарий</label>
                            <p class="mb-2">@Model.Comment</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Фото акта выполненных работ -->
        @if (Model.CompletionPhotos.Count > 0)
        {
            <div class="card mt-3">
                <div class="card-header">
                    <h6 class="mb-0"><i class="bi bi-camera"></i> Фото акта выполненных работ</h6>
                </div>
                <div class="card-body">
                    <div class="row g-2">
                        @for (var i = 0; i < Model.CompletionPhotos.Count; i++)
                        {
                            var photo = Model.CompletionPhotos[i];
                            <div class="col-4 col-md-3">
                                <a href="@photo.FilePath" target="_blank"
                                   class="completion-photo-link"
                                   data-index="@i"
                                   onclick="openCompletionGallery(@i); return false;">
                                    <img src="@photo.FilePath" alt="@photo.FileName"
                                         class="img-fluid rounded shadow-sm"
                                         style="width:100%;height:120px;object-fit:cover;cursor:pointer;" />
                                </a>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }

        <!-- Допустимые переходы -->
        @if (Model.AllowedTransitions.Length > 0)
        {
            <div class="card mt-3">
                <div class="card-header">
                    <h6 class="mb-0">Действия</h6>
                </div>
                <div class="card-body d-flex gap-2 flex-wrap">
                    @foreach (var transition in Model.AllowedTransitions)
                    {
                        var label = transition switch
                        {
                            TicketStatus.New => "Новая",
                            TicketStatus.Processed => "Взяли в работу",
                            TicketStatus.CompletedRemotely => "Дистанционно",
                            TicketStatus.PartsApproval => "Согласование",
                            TicketStatus.RepairApproved => "Согласована",
                            TicketStatus.DepartureConfirmation => "Подтверждение",
                            TicketStatus.EngineerEnRoute => "В пути",
                            TicketStatus.InProgress => "Выполнение",
                            TicketStatus.Completed => "Выполнена",
                            TicketStatus.ContinuationRequired => "Продолжение",
                            TicketStatus.Cancelled => "Отменена",
                            _ => transition.ToString()
                        };

                        var isCompletion = transition is TicketStatus.Completed or TicketStatus.CompletedRemotely;
                        if (isCompletion)
                        {
                            <button class="btn btn-outline-success btn-sm"
                                    onclick="showCompletionModal(@Model.Id, @((int)transition))">
                                <i class="bi bi-check-circle"></i> @label
                            </button>
                        }
                        else
                        {
                            <button class="btn btn-outline-primary btn-sm"
                                    onclick="updateStatus(@Model.Id, @((int)transition))">
                                @label
                            </button>
                        }
                    }
                </div>
            </div>
        }

        <!-- Чат -->
        <div class="card mt-3">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h6 class="mb-0"><i class="bi bi-chat-dots"></i> Чат</h6>
                <span id="chatOnlineCount" class="small text-muted"></span>
            </div>
            <div class="chat-container">
                <div id="chatMessages" class="chat-messages">
                    <div class="chat-empty">
                        <i class="bi bi-chat-text"></i>
                        <span>Загрузка сообщений...</span>
                    </div>
                </div>
                <div id="emojiPicker" class="emoji-picker"></div>
                <!-- Превью ответа на сообщение -->
                <div id="chatReplyPreview" class="chat-reply-preview" style="display:none">
                    <div class="chat-reply-preview-content">
                        <div class="chat-reply-preview-sender" id="replyPreviewSender"></div>
                        <div class="chat-reply-preview-text" id="replyPreviewText"></div>
                    </div>
                    <button type="button" class="chat-reply-preview-close" id="cancelReply" title="Отменить ответ">&times;</button>
                </div>
                <!-- Превью выбранных файлов -->
                <div id="chatFilePreview" class="chat-file-preview"></div>
                <form id="chatForm" class="chat-input-area">
                    <button type="button" class="btn-emoji" id="emojiToggle" title="Эмодзи">
                        <i class="bi bi-emoji-smile"></i>
                    </button>
                    <button type="button" class="btn-emoji" id="chatAttachBtn" title="Прикрепить файл">
                        <i class="bi bi-paperclip"></i>
                    </button>
                    <input type="file" id="chatFileInput" multiple accept="image/*,video/*" style="display:none" />
                    <textarea id="chatInput" rows="1" placeholder="Сообщение..." autocomplete="off"></textarea>
                    <button type="submit" class="btn-send" title="Отправить">
                        <i class="bi bi-send-fill"></i>
                    </button>
                </form>
            </div>
        </div>
    </div>

    <!-- Боковая панель -->
    <div class="col-md-4">
        <div class="card mb-3">
            <div class="card-header"><h6 class="mb-0">Детали</h6></div>
            <div class="card-body">
                <div class="mb-3">
                    <small class="text-muted">Точка обслуживания</small>
                    <p class="mb-1 fw-bold">@Model.ServicePointName</p>
                    <small class="text-muted"><i class="bi bi-geo-alt"></i> @Model.Address</small>
                </div>
                @if (Model.EquipmentModel is not null)
                {
                    <div class="mb-3">
                        <small class="text-muted">Оборудование</small>
                        <p class="mb-0">@Model.EquipmentModel (@Model.EquipmentSerialNumber)</p>
                    </div>
                }
                <div class="mb-3">
                    <small class="text-muted">Специалист</small>
                    @if (Model.EngineerName is not null)
                    {
                        <p class="mb-0"><i class="bi bi-person"></i> @Model.EngineerName</p>
                    }
                    else
                    {
                        <p class="mb-0 text-muted fst-italic">Не назначен</p>
                    }
                    @if (Model.CanAssignEngineer)
                    {
                        <div class="mt-2">
                            <select id="engineerSelect" class="form-select form-select-sm">
                                <option value="">Выберите специалиста...</option>
                            </select>
                            <button class="btn btn-sm btn-primary mt-1 w-100"
                                    onclick="assignEngineer(@Model.Id)">
                                <i class="bi bi-person-plus"></i> Назначить
                            </button>
                        </div>
                    }
                </div>
                <div class="mb-3">
                    <small class="text-muted">Создал</small>
                    <p class="mb-0">@Model.CreatedByName</p>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-header"><h6 class="mb-0">Даты</h6></div>
            <div class="card-body">
                <div class="mb-2">
                    <small class="text-muted">Создана</small>
                    <p class="mb-0">@Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")</p>
                </div>
                @if (Model.Deadline.HasValue)
                {
                    <div class="mb-2">
                        <small class="text-muted">Дедлайн</small>
                        <p class="mb-0 @(Model.Deadline < DateTime.Now ? "text-danger" : "")">
                            @Model.Deadline.Value.ToString("dd.MM.yyyy HH:mm")
                        </p>
                    </div>
                }
                @if (Model.WorkStartedAt.HasValue)
                {
                    <div class="mb-2">
                        <small class="text-muted">Начало работ</small>
                        <p class="mb-0">@Model.WorkStartedAt.Value.ToString("dd.MM.yyyy HH:mm")</p>
                    </div>
                }
                @if (Model.WorkCompletedAt.HasValue)
                {
                    <div class="mb-2">
                        <small class="text-muted">Завершена</small>
                        <p class="mb-0 text-success">@Model.WorkCompletedAt.Value.ToString("dd.MM.yyyy HH:mm")</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Модальное окно-галерея для просмотра вложений -->
<div class="modal fade" id="attachmentModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h6 class="modal-title" id="attachmentModalTitle"></h6>
                <div class="ms-auto d-flex align-items-center gap-2">
                    <small class="text-muted" id="attachmentCounter"></small>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Закрыть"></button>
                </div>
            </div>
            <div class="modal-body text-center p-2 position-relative" id="attachmentModalBody">
                <!-- Кнопка «Назад» -->
                <button type="button" id="galleryPrev"
                        class="btn btn-light rounded-circle position-absolute top-50 start-0 translate-middle-y ms-2 shadow-sm"
                        style="width:40px;height:40px;z-index:10;" onclick="galleryNav(-1)">
                    <i class="bi bi-chevron-left"></i>
                </button>
                <!-- Контент вложения -->
                <div id="galleryContent"></div>
                <!-- Кнопка «Вперёд» -->
                <button type="button" id="galleryNext"
                        class="btn btn-light rounded-circle position-absolute top-50 end-0 translate-middle-y me-2 shadow-sm"
                        style="width:40px;height:40px;z-index:10;" onclick="galleryNav(1)">
                    <i class="bi bi-chevron-right"></i>
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Модальное окно завершения заявки с фото -->
<div class="modal fade" id="completionModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h6 class="modal-title"><i class="bi bi-check-circle"></i> Завершение заявки</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Закрыть"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="completionTicketId" />
                <input type="hidden" id="completionNewStatus" />
                <div class="mb-3">
                    <label class="form-label">Комментарий (необязательно)</label>
                    <textarea id="completionComment" class="form-control" rows="2"></textarea>
                </div>
                <div class="mb-3">
                    <label class="form-label">Фото акта выполненных работ</label>
                    <input type="file" id="completionPhotos" class="form-control" multiple accept="image/*" />
                    <div class="form-text">Можно выбрать несколько фото</div>
                </div>
                <div id="completionPhotoPreview" class="row g-2 mt-2"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Отмена</button>
                <button type="button" class="btn btn-success btn-sm" onclick="submitCompletion()">
                    <i class="bi bi-check-circle"></i> Завершить
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Модальное окно-галерея для просмотра фото акта -->
<div class="modal fade" id="completionGalleryModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h6 class="modal-title">Фото акта</h6>
                <div class="ms-auto d-flex align-items-center gap-2">
                    <small class="text-muted" id="completionGalleryCounter"></small>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Закрыть"></button>
                </div>
            </div>
            <div class="modal-body text-center p-2 position-relative">
                <button type="button" id="completionGalleryPrev"
                        class="btn btn-light rounded-circle position-absolute top-50 start-0 translate-middle-y ms-2 shadow-sm"
                        style="width:40px;height:40px;z-index:10;" onclick="completionGalleryNav(-1)">
                    <i class="bi bi-chevron-left"></i>
                </button>
                <div id="completionGalleryContent"></div>
                <button type="button" id="completionGalleryNext"
                        class="btn btn-light rounded-circle position-absolute top-50 end-0 translate-middle-y me-2 shadow-sm"
                        style="width:40px;height:40px;z-index:10;" onclick="completionGalleryNav(1)">
                    <i class="bi bi-chevron-right"></i>
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/chat.js?dd=1" asp-append-version="true"></script>
    <script src="~/js/tickets.js?dd=1" asp-append-version="true"></script>
    <script>
        // Инициализация чата для текущей заявки
        initChat(@Model.Id, @User.GetUserId());

        // Данные фото акта для галереи
        var completionPhotos = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
            Model.CompletionPhotos.Select(p => new { p.FilePath, p.FileName }),
            new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase }));
    </script>
}
