@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var userRole = User.GetRole();
}

<nav class="sidebar" id="sidebar">
    <div class="sidebar-header p-3">
        <div class="d-flex align-items-center gap-2">
            <img src="/images/logo.svg" alt="TEAMWISE" style="height: 28px;" />
            <span class="sidebar-brand fw-bold">TEAMWISE</span>
        </div>
    </div>

    <ul class="nav flex-column sidebar-nav px-2">
        <li class="nav-item">
            <a class="nav-link @(currentController == "Home" ? "active" : "")" href="/">
                <i class="bi bi-speedometer2"></i>
                <span>Дашборд</span>
            </a>
        </li>

        <li class="nav-item">
            <a class="nav-link @(currentController == "Tickets" ? "active" : "")" href="/Tickets/Index">
                <i class="bi bi-ticket-detailed"></i>
                <span>Заявки</span>
            </a>
        </li>

        <li class="nav-item">
            <a class="nav-link @(currentController == "Equipment" ? "active" : "")" href="/Equipment/Index">
                <i class="bi bi-cpu"></i>
                <span>Оборудование</span>
            </a>
        </li>

        @if (userRole is not UserRole.Client and not UserRole.ManagerClient)
        {
            <li class="nav-item">
                <a class="nav-link @(currentController == "Chats" ? "active" : "")" href="/Chats/Index">
                    <i class="bi bi-chat-left-text"></i>
                    <span>Чаты</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(currentController == "CompanyChat" ? "active" : "")" href="/CompanyChat/Index">
                    <i class="bi bi-chat-dots"></i>
                    <span>Чат компании</span>
                </a>
            </li>
        }

        @if (userRole is UserRole.ChiefEngineer or UserRole.Logist
            or UserRole.ManagerTimewise or UserRole.Moderator)
        {
            <li class="nav-item">
                <a class="nav-link @(currentController == "Clients" ? "active" : "")" href="/Clients/Index">
                    <i class="bi bi-building"></i>
                    <span>Клиенты</span>
                </a>
            </li>
        }

        @if (userRole is UserRole.ChiefEngineer or UserRole.ManagerTimewise or UserRole.Moderator)
        {
            <li class="nav-item">
                <a class="nav-link @(currentController == "Reports" ? "active" : "")" href="/Reports/Dashboard">
                    <i class="bi bi-bar-chart-line"></i>
                    <span>Отчёты</span>
                </a>
            </li>
        }

        @if (userRole == UserRole.Moderator)
        {
            <li class="nav-item mt-3">
                <small class="nav-section-title px-3 text-muted text-uppercase">Администрирование</small>
            </li>
            <li class="nav-item">
                <a class="nav-link @(currentController == "Users" ? "active" : "")" href="/Users/Index">
                    <i class="bi bi-people"></i>
                    <span>Пользователи</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(currentController == "PersonalData" && ViewContext.RouteData.Values["action"]?.ToString() == "Requests" ? "active" : "")" href="/PersonalData/Requests">
                    <i class="bi bi-shield-lock"></i>
                    <span>ФЗ-152 Запросы ПД</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(currentController == "AuditLogs" ? "active" : "")" href="/AuditLogs/Index">
                    <i class="bi bi-journal-text"></i>
                    <span>Журнал аудита</span>
                </a>
            </li>
        }

        <li class="nav-item mt-3">
            <small class="nav-section-title px-3 text-muted text-uppercase">Настройки</small>
        </li>
        <li class="nav-item">
            <a class="nav-link @(currentController == "PersonalData" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")" href="/PersonalData/Index">
                <i class="bi bi-person-lock"></i>
                <span>Мои данные (ФЗ-152)</span>
            </a>
        </li>
    </ul>
</nav>
