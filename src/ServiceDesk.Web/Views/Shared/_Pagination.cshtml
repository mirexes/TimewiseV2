@model dynamic

@{
    int page = Model.Page;
    int totalPages = Model.TotalPages;
    bool hasPrev = Model.HasPreviousPage;
    bool hasNext = Model.HasNextPage;

    // Сохраняем текущие query-параметры при переключении страниц
    var query = Context.Request.Query;
    string BuildPageUrl(int p)
    {
        var parameters = new List<string> { $"page={p}" };
        foreach (var kvp in query)
        {
            if (kvp.Key.Equals("page", StringComparison.OrdinalIgnoreCase))
                continue;
            foreach (var val in kvp.Value)
                parameters.Add($"{Uri.EscapeDataString(kvp.Key)}={Uri.EscapeDataString(val ?? "")}");
        }
        return "?" + string.Join("&", parameters);
    }
}

@if (totalPages > 1)
{
    <nav aria-label="Навигация по страницам">
        <ul class="pagination justify-content-center mt-4">
            <li class="page-item @(hasPrev ? "" : "disabled")">
                <a class="page-link" href="@BuildPageUrl(page - 1)">
                    <i class="bi bi-chevron-left"></i>
                </a>
            </li>

            @for (var i = Math.Max(1, page - 2); i <= Math.Min(totalPages, page + 2); i++)
            {
                <li class="page-item @(i == page ? "active" : "")">
                    <a class="page-link" href="@BuildPageUrl(i)">@i</a>
                </li>
            }

            <li class="page-item @(hasNext ? "" : "disabled")">
                <a class="page-link" href="@BuildPageUrl(page + 1)">
                    <i class="bi bi-chevron-right"></i>
                </a>
            </li>
        </ul>
    </nav>
}
