@{
    ViewData["Title"] = "Ошибка";
    Layout = "_Layout";
    var code = ViewBag.ErrorCode ?? 500;
}

<div class="d-flex flex-column align-items-center justify-content-center" style="min-height: 50vh;">
    <div class="text-center">
        <h1 class="display-1 fw-bold text-muted">@code</h1>
        <p class="fs-4 text-secondary">
            @switch ((int)code)
            {
                case 404:
                    @:Страница не найдена
                    break;
                case 400:
                    @:Некорректный запрос
                    break;
                case 403:
                    @:Доступ запрещён
                    break;
                default:
                    @:Что-то пошло не так
                    break;
            }
        </p>
        <a href="/" class="btn btn-primary mt-3">
            <i class="bi bi-house"></i> На главную
        </a>
    </div>
</div>
