@model EquipmentDto
@{
    ViewData["Title"] = $"Оборудование: {Model.Model}";
    var history = ViewBag.History as IEnumerable<EquipmentHistoryDto>
        ?? Enumerable.Empty<EquipmentHistoryDto>();
}

<div class="mb-3">
    <a href="/Equipment" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left"></i> К списку
    </a>
</div>

<div class="row g-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header"><h5 class="mb-0">@Model.Model</h5></div>
            <div class="card-body">
                <div class="mb-3">
                    <small class="text-muted">Серийный номер</small>
                    <p class="mb-0 fw-bold">@Model.SerialNumber</p>
                </div>
                <div class="mb-3">
                    <small class="text-muted">Точка обслуживания</small>
                    <p class="mb-0">@Model.ServicePointName</p>
                    <small class="text-muted"><i class="bi bi-geo-alt"></i> @Model.ServicePointAddress</small>
                </div>
                @if (Model.InstalledAt.HasValue)
                {
                    <div class="mb-3">
                        <small class="text-muted">Дата установки</small>
                        <p class="mb-0">@Model.InstalledAt.Value.ToString("dd.MM.yyyy")</p>
                    </div>
                }
                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <div>
                        <small class="text-muted">Описание</small>
                        <p class="mb-0">@Model.Description</p>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h6 class="mb-0"><i class="bi bi-clock-history"></i> История ремонта</h6>
            </div>
            <div class="card-body">
                @if (!history.Any())
                {
                    <p class="text-muted text-center">Нет записей</p>
                }
                else
                {
                    @foreach (var record in history)
                    {
                        <div class="d-flex justify-content-between align-items-start border-bottom py-2">
                            <div>
                                <a href="/Tickets/Details/@record.TicketId" class="text-decoration-none fw-bold">
                                    @record.TicketNumber
                                </a>
                                <p class="small text-muted mb-0">@record.Description</p>
                            </div>
                            <small class="text-muted text-nowrap">@record.CreatedAt.ToString("dd.MM.yy")</small>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>
