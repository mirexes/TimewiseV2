@using ServiceDesk.Core.DTOs.Equipment
@model PagedResultDto<EquipmentDto>
@{
    ViewData["Title"] = "Оборудование";
    var search = ViewBag.Search as string ?? "";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <span class="text-muted">Всего: @Model.TotalCount</span>
    <a href="/Equipment/Create" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-lg"></i> Добавить
    </a>
</div>

<div class="card mb-4">
    <div class="card-body py-2">
        <form method="get" class="row g-2 align-items-end">
            <div class="col">
                <label class="form-label small text-muted mb-0">Серийный номер</label>
                <input type="text" name="search" value="@search" class="form-control form-control-sm"
                       placeholder="Поиск по серийному номеру..." />
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-outline-primary btn-sm">
                    <i class="bi bi-search"></i>
                </button>
            </div>
            @if (!string.IsNullOrEmpty(search))
            {
                <div class="col-auto">
                    <a href="/Equipment/Index" class="btn btn-outline-secondary btn-sm">Сбросить</a>
                </div>
            }
        </form>
    </div>
</div>

@if (!Model.Items.Any())
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-cpu fs-1"></i>
        <p class="mt-2">Оборудование не найдено</p>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var eq in Model.Items)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card h-100" onclick="location.href='/Equipment/Details/@eq.Id'"
                     style="cursor: pointer;">
                    <div class="card-body">
                        <h6 class="card-title">
                            <i class="bi bi-cpu"></i> @eq.Model
                        </h6>
                        <p class="text-muted small mb-1">S/N: @eq.SerialNumber</p>
                        @if (!string.IsNullOrEmpty(eq.ServicePointAddress))
                        {
                            <a href="https://yandex.ru/maps/?text=@(Uri.EscapeDataString(eq.ServicePointAddress))"
                               target="_blank" rel="noopener noreferrer" class="text-decoration-none"
                               onclick="event.stopPropagation();">
                                <p class="small mb-0 link-primary"><i class="bi bi-geo-alt"></i> @eq.ServicePointAddress</p>
                            </a>
                        }
                        else
                        {
                            <p class="text-muted small mb-0"><i class="bi bi-geo-alt"></i> Адрес не указан</p>
                        }
                        @if (eq.InstalledAt.HasValue)
                        {
                            <small class="text-muted">
                                Установлено: @eq.InstalledAt.Value.ToString("dd.MM.yyyy")
                            </small>
                        }
                    </div>
                </div>
            </div>
        }
    </div>

    @await Html.PartialAsync("_Pagination", Model)
}
