@model CreateEquipmentDto
@{
    ViewData["Title"] = "Добавить оборудование";
    var servicePoints = ViewBag.ServicePoints as IEnumerable<SelectOptionDto>
        ?? Enumerable.Empty<SelectOptionDto>();
    var yandexApiKey = (string)(ViewBag.YandexMapsApiKey ?? "");
}

<div class="mb-3">
    <a href="/Equipment/Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left"></i> К списку
    </a>
</div>

<div class="card" style="max-width: 600px;">
    <div class="card-header"><h5 class="mb-0">Новое оборудование</h5></div>
    <div class="card-body">
        <form asp-action="Create" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="mb-3">
                <label asp-for="Model" class="form-label">Модель</label>
                <input asp-for="Model" class="form-control" placeholder="Название модели" />
                <span asp-validation-for="Model" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="SerialNumber" class="form-label">Серийный номер</label>
                <input asp-for="SerialNumber" class="form-control" placeholder="S/N" />
                <span asp-validation-for="SerialNumber" class="text-danger small"></span>
            </div>

            <!-- Точка обслуживания — поиск с фильтрацией -->
            <div class="mb-3">
                <label asp-for="ServicePointId" class="form-label">Точка обслуживания</label>
                <input type="hidden" name="ServicePointId" id="servicePointValue"
                       value="@(Model?.ServicePointId)" />
                <div class="position-relative" id="spSearchWrapper">
                    <input type="text" class="form-control" id="servicePointSearch"
                           placeholder="Начните вводить адрес..." autocomplete="off" />
                    <div id="servicePointList"
                         class="list-group position-absolute w-100 shadow"
                         style="z-index: 1050; display: none; max-height: 250px; overflow-y: auto;">
                    </div>
                </div>
                <script id="spOptionsData" type="application/json">@Html.Raw(System.Text.Json.JsonSerializer.Serialize(servicePoints.Select(sp => new { sp.Id, sp.Text })))</script>
                <span asp-validation-for="ServicePointId" class="text-danger small"></span>

                @if (!string.IsNullOrEmpty(yandexApiKey))
                {
                    <div class="mt-2">
                        <button type="button" class="btn btn-outline-primary btn-sm" id="btnShowMap">
                            <i class="bi bi-geo-alt"></i> Указать новый адрес на карте
                        </button>
                    </div>

                    <!-- Скрытые поля для нового адреса -->
                    <input type="hidden" name="NewAddress" id="newAddress" />
                    <input type="hidden" name="Latitude" id="newLatitude" />
                    <input type="hidden" name="Longitude" id="newLongitude" />

                    <!-- Блок карты (скрыт по умолчанию) -->
                    <div id="mapContainer" class="mt-2" style="display: none;">
                        <div class="mb-2 position-relative">
                            <input type="text" id="addressSearch" class="form-control"
                                   placeholder="Введите адрес для поиска..." autocomplete="off" />
                            <div id="suggestList" class="list-group position-absolute w-100 shadow"
                                 style="z-index: 1050; display: none; max-height: 250px; overflow-y: auto;"></div>
                        </div>
                        <div id="yandexMap" style="width: 100%; height: 350px; border-radius: 8px;"></div>
                        <div id="selectedAddress" class="mt-2 text-muted small" style="display: none;">
                            <i class="bi bi-geo-alt-fill"></i> <span id="addressText"></span>
                        </div>
                    </div>
                }
            </div>

            <div class="mb-3">
                <label asp-for="InstalledAt" class="form-label">Дата установки</label>
                <input asp-for="InstalledAt" type="date" class="form-control" />
            </div>
            <div class="mb-3">
                <label asp-for="Description" class="form-label">Описание</label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
            </div>

            <div class="mb-3 form-check">
                <input asp-for="IsCompanyOwned" class="form-check-input" type="checkbox" />
                <label asp-for="IsCompanyOwned" class="form-check-label">
                    Подменное оборудование (собственность компании)
                </label>
                <div class="form-text">Используется для подмены на период ремонта оборудования клиента</div>
            </div>

            <!-- Фото оборудования -->
            <div class="mb-3">
                <label class="form-label">Фото оборудования</label>
                <input type="file" name="photo" id="photoInput"
                       class="form-control" accept="image/*" />
                <div class="form-text">Можно прикрепить фото кофемашины</div>
                <div id="photoPreview" class="mt-2"></div>
            </div>

            <button type="submit" class="btn btn-primary">
                <i class="bi bi-check-lg"></i> Добавить
            </button>
            <a href="/Equipment/Index" class="btn btn-outline-secondary ms-2">Отмена</a>
        </form>
    </div>
</div>

@section Scripts {
    @if (!string.IsNullOrEmpty(yandexApiKey))
    {
        <script src="https://api-maps.yandex.ru/2.1/?apikey=@yandexApiKey&lang=ru_RU&load=package.full"></script>
    }
    <script src="~/js/equipment-create.js" asp-append-version="true"></script>
}
