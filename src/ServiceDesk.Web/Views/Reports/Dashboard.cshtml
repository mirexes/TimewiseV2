@model DashboardStatsDto
@{
    ViewData["Title"] = "Отчёты — Дашборд";
}

<!-- Навигация по разделам отчётов -->
<ul class="nav nav-tabs mb-4">
    <li class="nav-item">
        <a class="nav-link active" href="/Reports/Dashboard">
            <i class="bi bi-speedometer2"></i> Дашборд
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link" href="/Reports/Engineers">
            <i class="bi bi-people"></i> Специалисты
        </a>
    </li>
</ul>

<!-- Карточки статистики -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <a href="/Tickets/Index" class="text-decoration-none">
            <div class="card stat-card stat-card-link">
                <div class="card-body text-center">
                    <div class="stat-icon text-primary mb-2">
                        <i class="bi bi-ticket-detailed fs-1"></i>
                    </div>
                    <h2 class="stat-number">@Model.TotalTickets</h2>
                    <p class="stat-label text-muted mb-0">Всего заявок</p>
                </div>
            </div>
        </a>
    </div>
    <div class="col-6 col-md-3">
        <a href="/Tickets/Index?Status=New" class="text-decoration-none">
            <div class="card stat-card stat-card-link">
                <div class="card-body text-center">
                    <div class="stat-icon text-info mb-2">
                        <i class="bi bi-plus-circle fs-1"></i>
                    </div>
                    <h2 class="stat-number">@Model.NewTickets</h2>
                    <p class="stat-label text-muted mb-0">Новые</p>
                </div>
            </div>
        </a>
    </div>
    <div class="col-6 col-md-3">
        <a href="/Tickets/Index?Status=InProgress" class="text-decoration-none">
            <div class="card stat-card stat-card-link">
                <div class="card-body text-center">
                    <div class="stat-icon text-warning mb-2">
                        <i class="bi bi-arrow-repeat fs-1"></i>
                    </div>
                    <h2 class="stat-number">@Model.InProgressTickets</h2>
                    <p class="stat-label text-muted mb-0">В работе</p>
                </div>
            </div>
        </a>
    </div>
    <div class="col-6 col-md-3">
        <a href="/Tickets/Index?Status=Completed" class="text-decoration-none">
            <div class="card stat-card stat-card-link">
                <div class="card-body text-center">
                    <div class="stat-icon text-success mb-2">
                        <i class="bi bi-check-circle fs-1"></i>
                    </div>
                    <h2 class="stat-number">@Model.CompletedTickets</h2>
                    <p class="stat-label text-muted mb-0">Выполнены</p>
                </div>
            </div>
        </a>
    </div>
</div>

<!-- Просроченные заявки -->
@if (Model.OverdueTickets > 0)
{
    <div class="alert alert-danger d-flex align-items-center gap-2 mb-4">
        <i class="bi bi-exclamation-triangle-fill fs-4"></i>
        <span>Просроченных заявок: <strong>@Model.OverdueTickets</strong></span>
        <a href="/Tickets/Index?Status=InProgress" class="btn btn-outline-danger btn-sm ms-auto">Посмотреть</a>
    </div>
}

<!-- Графики -->
<div class="row g-3 mb-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h6 class="mb-0"><i class="bi bi-pie-chart"></i> Заявки по статусам</h6>
            </div>
            <div class="card-body">
                <canvas id="statusChart" height="250"></canvas>
                @if (!Model.TicketsByStatus.Any())
                {
                    <p class="text-center text-muted mt-3">Нет данных</p>
                }
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h6 class="mb-0"><i class="bi bi-graph-up"></i> Заявки за 30 дней</h6>
            </div>
            <div class="card-body">
                <canvas id="dailyChart" height="250"></canvas>
                @if (!Model.TicketsByDay.Any())
                {
                    <p class="text-center text-muted mt-3">Нет данных</p>
                }
            </div>
        </div>
    </div>
</div>

<!-- Доп. инфо -->
<div class="row g-3">
    <div class="col-md-4">
        <div class="card">
            <div class="card-body d-flex align-items-center gap-3">
                <i class="bi bi-cpu fs-2 text-primary"></i>
                <div>
                    <h4 class="mb-0">@Model.TotalEquipment</h4>
                    <small class="text-muted">Оборудование</small>
                </div>
            </div>
        </div>
    </div>
    @if (Model.TotalClients > 0)
    {
        <div class="col-md-4">
            <div class="card">
                <div class="card-body d-flex align-items-center gap-3">
                    <i class="bi bi-building fs-2 text-primary"></i>
                    <div>
                        <h4 class="mb-0">@Model.TotalClients</h4>
                        <small class="text-muted">Клиенты</small>
                    </div>
                </div>
            </div>
        </div>
    }
    @if (Model.TotalEngineers > 0)
    {
        <div class="col-md-4">
            <div class="card">
                <div class="card-body d-flex align-items-center gap-3">
                    <i class="bi bi-people fs-2 text-primary"></i>
                    <div>
                        <h4 class="mb-0">@Model.TotalEngineers</h4>
                        <small class="text-muted">Специалисты</small>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
    <script>
        // Данные с сервера
        const statusData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.TicketsByStatus));
        const dailyData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.TicketsByDay));

        // Локализация статусов
        const statusLabels = {
            'New': 'Новая',
            'Processed': 'Обработана',
            'CompletedRemotely': 'Дистанционно',
            'PartsApproval': 'Согласование запчастей',
            'RepairApproved': 'Ремонт одобрен',
            'InProgress': 'В работе',
            'EngineerEnRoute': 'Инженер в пути',
            'Execution': 'Выполнение',
            'Completed': 'Выполнена',
            'ContinuationRequired': 'Требуется продолжение',
            'Cancelled': 'Отменена'
        };

        // Круговой график - заявки по статусам
        if (Object.keys(statusData).length > 0) {
            new Chart(document.getElementById('statusChart'), {
                type: 'doughnut',
                data: {
                    labels: Object.keys(statusData).map(k => statusLabels[k] || k),
                    datasets: [{
                        data: Object.values(statusData),
                        backgroundColor: [
                            '#0dcaf0', '#ffc107', '#198754', '#fd7e14',
                            '#0d6efd', '#6f42c1', '#dc3545', '#20c997',
                            '#d63384', '#6c757d', '#adb5bd'
                        ]
                    }]
                },
                options: {
                    responsive: true,
                    plugins: { legend: { position: 'bottom' } }
                }
            });
        }

        // Линейный график - заявки за 30 дней
        if (Object.keys(dailyData).length > 0) {
            new Chart(document.getElementById('dailyChart'), {
                type: 'line',
                data: {
                    labels: Object.keys(dailyData),
                    datasets: [{
                        label: 'Заявки',
                        data: Object.values(dailyData),
                        borderColor: '#0d6efd',
                        backgroundColor: 'rgba(13, 110, 253, 0.1)',
                        fill: true,
                        tension: 0.3
                    }]
                },
                options: {
                    responsive: true,
                    plugins: { legend: { display: false } },
                    scales: {
                        y: { beginAtZero: true, ticks: { stepSize: 1 } }
                    }
                }
            });
        }
    </script>
}
