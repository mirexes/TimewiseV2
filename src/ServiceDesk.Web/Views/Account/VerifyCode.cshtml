@model VerifyCodeDto
@{
    ViewData["Title"] = "Подтверждение";
    Layout = "_Layout";
}

<div class="d-flex justify-content-center align-items-center" style="min-height: 70vh;">
    <div class="card login-card" style="width: 100%; max-width: 400px;">
        <div class="card-body p-4">
            <div class="text-center mb-4">
                <i class="bi bi-shield-lock fs-1 text-primary"></i>
                <h4 class="mt-2">Введите код</h4>
                <p class="text-muted">SMS отправлен на @Model.Phone</p>
            </div>

            <form asp-action="VerifyCode" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Phone" />
                <div asp-validation-summary="All" class="alert alert-danger d-none"></div>

                <div class="mb-3">
                    <label asp-for="Code" class="form-label">Код из SMS</label>
                    <input asp-for="Code" class="form-control form-control-lg text-center"
                           maxlength="6" placeholder="____" autofocus
                           style="letter-spacing: 0.5em; font-size: 1.5rem;" />
                    <span asp-validation-for="Code" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-primary w-100">
                    <i class="bi bi-check-lg"></i> Подтвердить
                </button>

                <div class="text-center mt-3">
                    <a href="/Account/Login" class="text-muted small">
                        <i class="bi bi-arrow-left"></i> Другой номер
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>
