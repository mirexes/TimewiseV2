@model SendCodeDto
@{
    ViewData["Title"] = "Вход";
    Layout = "_Layout";
}

<div class="d-flex justify-content-center align-items-center" style="min-height: 70vh;">
    <div class="card login-card" style="width: 100%; max-width: 400px;">
        <div class="card-body p-4">
            <div class="text-center mb-4">
                <img src="/images/logo.svg" alt="TEAMWISE" style="height: 40px;" class="mb-2" />
                <h4 class="mt-2">TEAMWISE</h4>
                <p class="text-muted">Войдите по номеру телефона</p>
            </div>

            <form asp-action="Login" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="All" class="alert alert-danger d-none"></div>

                <div class="mb-3">
                    <label asp-for="Phone" class="form-label">Номер телефона</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-phone"></i></span>
                        <input asp-for="Phone" class="form-control" placeholder="+7 (___) ___-__-__"
                               type="tel" autofocus />
                    </div>
                    <span asp-validation-for="Phone" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-primary w-100">
                    <i class="bi bi-send"></i> Получить код
                </button>

                <div class="text-center mt-3">
                    <small class="text-muted">
                        Нажимая «Получить код», вы соглашаетесь с
                        <a href="/PersonalData/PrivacyPolicy" target="_blank">политикой обработки персональных данных</a>
                    </small>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Показываем блок ошибок если есть
        const validationSummary = document.querySelector('[data-valmsg-summary]');
        if (validationSummary && validationSummary.querySelector('li')) {
            validationSummary.classList.remove('d-none');
        }

        // Валидация и форматирование телефона
        const phoneInput = document.getElementById('Phone');
        if (phoneInput) {
            // Если поле пустое — подставляем +7
            phoneInput.addEventListener('focus', function () {
                if (!this.value) this.value = '+7';
            });

            phoneInput.addEventListener('input', function () {
                // Убираем всё кроме цифр и +
                let val = this.value.replace(/[^\d+]/g, '');

                // Гарантируем + в начале
                if (!val.startsWith('+')) {
                    // 8xxxx → +7xxxx (замена 8 на +7 для России)
                    if (val.startsWith('8') && val.length >= 2) {
                        val = '+7' + val.substring(1);
                    } else {
                        val = '+' + val;
                    }
                }

                this.value = val;
            });

            // Валидация перед отправкой
            phoneInput.closest('form').addEventListener('submit', function (e) {
                const val = phoneInput.value.trim();
                const errorSpan = document.querySelector('[data-valmsg-for="Phone"]');

                if (!/^\+\d{10,15}$/.test(val)) {
                    e.preventDefault();
                    if (errorSpan) {
                        errorSpan.textContent = 'Номер должен начинаться с + и содержать код страны, например +79618934486';
                        errorSpan.classList.add('field-validation-error');
                    }
                    return;
                }

                if (errorSpan) {
                    errorSpan.textContent = '';
                    errorSpan.classList.remove('field-validation-error');
                }
            });
        }
    </script>
}
