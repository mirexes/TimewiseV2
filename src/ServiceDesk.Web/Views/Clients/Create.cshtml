@model CreateClientDto
@{
    ViewData["Title"] = "Новый клиент";
}

<div class="mb-3">
    <a href="/Clients" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left"></i> К списку
    </a>
</div>

<div class="card" style="max-width: 600px;">
    <div class="card-header"><h5 class="mb-0">Новый клиент</h5></div>
    <div class="card-body">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="mb-3">
                <label asp-for="Name" class="form-label">Наименование организации *</label>
                <input asp-for="Name" class="form-control" placeholder="ООО «Кофе и Ко»" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Inn" class="form-label">ИНН</label>
                <input asp-for="Inn" class="form-control" placeholder="1234567890" maxlength="12" />
                <span asp-validation-for="Inn" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Network" class="form-label">Сеть</label>
                <input asp-for="Network" class="form-control" placeholder="Название сети" />
                <span asp-validation-for="Network" class="text-danger small"></span>
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Phone" class="form-label">Телефон</label>
                    <input asp-for="Phone" type="tel" class="form-control" placeholder="+7 (999) 123-45-67" />
                    <span asp-validation-for="Phone" class="text-danger small"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Email" class="form-label">Email</label>
                    <input asp-for="Email" type="email" class="form-control" placeholder="info@company.ru" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>
            </div>
            <div class="mb-3">
                <label asp-for="LegalAddress" class="form-label">Юридический адрес</label>
                <textarea asp-for="LegalAddress" class="form-control" rows="2"
                          placeholder="г. Москва, ул. Примерная, д. 1"></textarea>
                <span asp-validation-for="LegalAddress" class="text-danger small"></span>
            </div>
            <div class="mb-3 form-check">
                <input asp-for="IsActive" type="checkbox" class="form-check-input" checked="checked" />
                <label asp-for="IsActive" class="form-check-label">Активен</label>
            </div>

            <button type="submit" class="btn btn-primary">
                <i class="bi bi-check-lg"></i> Создать
            </button>
            <a href="/Clients" class="btn btn-outline-secondary ms-2">Отмена</a>
        </form>
    </div>
</div>
