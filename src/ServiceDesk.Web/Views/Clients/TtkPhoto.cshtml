@model ClientDetailDto
@{
    ViewData["Title"] = $"ТТК настроек: {Model.Name}";
}

<div class="mb-3">
    <a href="javascript:history.back()" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left"></i> Назад
    </a>
</div>

<div class="card">
    <div class="card-header">
        <h5 class="mb-0"><i class="bi bi-image"></i> ТТК настроек — @Model.Name</h5>
    </div>
    <div class="card-body text-center">
        @if (!string.IsNullOrEmpty(Model.TtkFilePath))
        {
            <img src="@Model.TtkFilePath" alt="Фото ТТК настроек" class="img-fluid rounded"
                 style="max-width: 100%; cursor: pointer;"
                 onclick="window.open(this.src, '_blank')" />
            <p class="text-muted small mt-2">Нажмите на изображение для просмотра в полном размере</p>
        }
        else
        {
            <p class="text-muted">Фото ТТК не загружено</p>
        }
    </div>
</div>
